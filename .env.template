# N8N Social Media Automation Environment Configuration Template
# Copy this file to .env and update with your actual values

# N8N Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=mySuperSecretEncryptionKey

# Database Configuration
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8n123

# Redis Configuration
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=redis123

# Google Sheets Configuration
GOOGLE_LINKEDIN_CONTENT_SHEET_ID=your-linkedin-content-sheet-id
GOOGLE_INSTAGRAM_CONTENT_SHEET_ID=your-instagram-content-sheet-id
GOOGLE_CROSS_PLATFORM_CONTENT_SHEET_ID=your-cross-platform-content-sheet-id
GOOGLE_LINKEDIN_ANALYTICS_SHEET_ID=your-linkedin-analytics-sheet-id
GOOGLE_INSTAGRAM_ANALYTICS_SHEET_ID=your-instagram-analytics-sheet-id
GOOGLE_CROSS_PLATFORM_ANALYTICS_SHEET_ID=your-cross-platform-analytics-sheet-id
GOOGLE_INSTAGRAM_INSIGHTS_SHEET_ID=your-instagram-insights-sheet-id

# LinkedIn API Configuration
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Instagram API Configuration
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# Telegram Configuration (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Webhook URLs
WEBHOOK_BASE_URL=http://localhost:5678/webhook
LINKEDIN_WEBHOOK_PATH=linkedin-webhook
INSTAGRAM_WEBHOOK_PATH=instagram-webhook
CROSS_PLATFORM_WEBHOOK_PATH=cross-platform-webhook

# Posting Schedule Configuration
LINKEDIN_POSTING_INTERVAL=8  # Hours
INSTAGRAM_POSTING_INTERVAL=12  # Hours
CROSS_PLATFORM_POSTING_INTERVAL=6  # Hours
DAILY_INSIGHTS_INTERVAL=24  # Hours

# Content Configuration
MAX_LINKEDIN_CONTENT_LENGTH=3000
MAX_INSTAGRAM_CONTENT_LENGTH=2200
DEFAULT_HASHTAG_COUNT=10

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_DIRECTORY=backups

# Logging Configuration
LOG_LEVEL=info
LOG_RETENTION_DAYS=7