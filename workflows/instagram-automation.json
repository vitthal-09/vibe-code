    {
      "parameters": {
        "functionCode": "// Generate relevant hashtags based on content\nconst content = $input.first().json.caption || '';\nconst keywords = content.toLowerCase().split(' ').filter(word => word.length > 3);\n\nconst hashtagCategories = {\n  business: ['#business', '#entrepreneur', '#startup', '#marketing', '#leadership'],\n  tech: ['#technology', '#innovation', '#digital', '#ai', '#automation'],\n  lifestyle: ['#lifestyle', '#motivation', '#success', '#growth', '#mindset'],\n  social: ['#socialmedia', '#instagram', '#linkedin', '#networking', '#community']\n};\n\nlet relevantHashtags = [];\n\n// Add hashtags based on content keywords\nkeywords.forEach(keyword => {\n  if (keyword.includes('business') || keyword.includes('entrepreneur')) {\n    relevantHashtags.push(...hashtagCategories.business);\n  }\n  if (keyword.includes('tech') || keyword.includes('digital')) {\n    relevantHashtags.push(...hashtagCategories.tech);\n  }\n  if (keyword.includes('life') || keyword.includes('success')) {\n    relevantHashtags.push(...hashtagCategories.lifestyle);\n  }\n});\n\n// Add general hashtags\nrelevantHashtags.push(...hashtagCategories.social);\n\n// Remove duplicates and limit to 30 hashtags\nconst uniqueHashtags = [...new Set(relevantHashtags)].slice(0, 30);\n\nreturn [{ json: { hashtags: uniqueHashtags.join(' ') } }];"
      },
