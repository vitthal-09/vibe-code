    {
      "parameters": {
        "functionCode": "// Wait for video processing\nconst containerId = $json.id;\nconst maxAttempts = 30;\nlet attempt = 0;\nlet status = 'IN_PROGRESS';\n\nwhile (status === 'IN_PROGRESS' && attempt < maxAttempts) {\n  await new Promise(resolve => setTimeout(resolve, 10000)); // Wait 10 seconds\n  \n  const response = await $workflow.httpRequest({\n    url: `https://graph.facebook.com/v18.0/${containerId}`,\n    method: 'GET',\n    qs: {\n      fields: 'status_code',\n      access_token: $credentials.access_token\n    }\n  });\n  \n  status = response.status_code;\n  attempt++;\n}\n\nif (status === 'FINISHED') {\n  return { id: containerId, status: 'ready' };\n} else {\n  throw new Error(`Video processing failed with status: ${status}`);\n}"
      },
      "id": "9c0d1e2f-3a4b-5c6d-7e8f901234567890",
      "name": "Wait for Video Processing",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1050, 600]
    },
