    {
      "parameters": {
        "jsCode": "// Performance analytics aggregator\nconst items = $input.all();\nconst analytics = {\n  totalPosts: items.length,\n  platforms: {},\n  categories: {},\n  successRate: 0,\n  timestamp: new Date().toISOString()\n};\n\nlet successfulPosts = 0;\n\nfor (const item of items) {\n  const platform = item.json.platform;\n  const category = item.json.category;\n  const isSuccess = item.json.id ? true : false;\n  \n  if (isSuccess) successfulPosts++;\n  \n  // Platform stats\n  if (!analytics.platforms[platform]) {\n    analytics.platforms[platform] = { count: 0, successful: 0 };\n  }\n  analytics.platforms[platform].count++;\n  if (isSuccess) analytics.platforms[platform].successful++;\n  \n  // Category stats\n  if (!analytics.categories[category]) {\n    analytics.categories[category] = { count: 0, successful: 0 };\n  }\n  analytics.categories[category].count++;\n  if (isSuccess) analytics.categories[category].successful++;\n}\n\nanalytics.successRate = (successfulPosts / items.length) * 100;\n\nreturn [{ json: analytics }];"
      },
      "id": "performance-aggregator",
      "name": "Performance Analytics Aggregator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        550
      ]
