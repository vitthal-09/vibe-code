          "id": "2",
          "name": "LinkedIn OAuth2"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE content_calendar SET status = 'published', published_at = NOW(), post_id = '{{$json[\"id\"]}}' WHERE id = {{$node[\"Get Scheduled Posts\"].json[\"id\"]}};",
        "options": {}
      },
      "id": "e25f6e91-8901-2345-6123-789012345678",
      "name": "Update Post Status",
