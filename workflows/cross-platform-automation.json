    {
      "parameters": {
        "jsCode": "// Cross-platform content adapter\nconst items = $input.all();\nconst processedItems = [];\n\nfor (const item of items) {\n  const baseContent = item.json.content || '';\n  const imageUrl = item.json.image_url || '';\n  const platforms = (item.json.platforms || 'linkedin,instagram').split(',').map(p => p.trim());\n  const category = item.json.category || 'general';\n  const postType = item.json.post_type || 'post'; // post, story, article\n  \n  if (baseContent) {\n    // Create platform-specific versions\n    platforms.forEach(platform => {\n      let adaptedContent = baseContent;\n      let adaptedImageUrl = imageUrl;\n      \n      if (platform === 'linkedin') {\n        // LinkedIn optimizations\n        adaptedContent = adaptedContent.length > 3000 ? \n          adaptedContent.substring(0, 2997) + '...' : adaptedContent;\n        \n        // Add professional hashtags for LinkedIn\n        const linkedinHashtags = ['#professional', '#business', '#networking', '#career'];\n        adaptedContent += '\\n\\n' + linkedinHashtags.slice(0, 3).join(' ');\n        \n      } else if (platform === 'instagram') {\n        // Instagram optimizations\n        const instagramHashtags = {\n          business: ['#entrepreneur', '#startup', '#businessowner', '#success', '#growth'],\n          tech: ['#technology', '#innovation', '#digital', '#startup', '#tech'],\n          lifestyle: ['#lifestyle', '#inspiration', '#motivation', '#wellness'],\n          general: ['#instagood', '#photooftheday', '#follow', '#instadaily']\n        };\n        \n        const selectedHashtags = instagramHashtags[category] || instagramHashtags.general;\n        adaptedContent += '\\n\\n' + selectedHashtags.join(' ');\n        \n        // Ensure Instagram character limit\n        adaptedContent = adaptedContent.length > 2200 ? \n          adaptedContent.substring(0, 2197) + '...' : adaptedContent;\n      }\n      \n      processedItems.push({\n        json: {\n          ...item.json,\n          platform: platform,\n          content: adaptedContent,\n          originalContent: baseContent,\n          imageUrl: adaptedImageUrl,\n          category: category,\n          postType: postType,\n          timestamp: new Date().toISOString()\n        }\n      });\n    });\n  }\n}\n\nreturn processedItems;"
      },
