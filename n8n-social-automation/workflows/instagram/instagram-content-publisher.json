          "string": [
            {
              "name": "workflow",
              "value": "Instagram Content Publisher"
            },
            {
              "name": "status",
              "value": "success"
            },
            {
              "name": "published_count",
              "value": "={{$items.length}}"
            },
            {
              "name": "timestamp",
              "value": "={{$now}}"
            }
          ]
        },
        "options": {}
      },
      "id": "3a4b5c6d-7e8f-9012-3456789012345678",
      "name": "Success Summary",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "functionCode": "// Error handling and retry logic\nconst error = $json.error || 'Unknown error';\nconst contentId = $node[\"Get Scheduled Content\"].json.id;\nconst retryCount = $node[\"Get Scheduled Content\"].json.retry_count || 0;\n\nif (retryCount < 3) {\n  // Update retry count and reschedule\n  await $workflow.postgres.executeQuery({\n    query: `UPDATE content_calendar SET retry_count = ${retryCount + 1}, scheduled_time = NOW() + INTERVAL '30 minutes' WHERE id = ${contentId}`\n  });\n} else {\n  // Mark as failed after 3 retries\n  await $workflow.postgres.executeQuery({\n    query: `UPDATE content_calendar SET status = 'failed', error_message = '${error}' WHERE id = ${contentId}`\n  });\n}\n\nreturn {\n  status: 'error',\n  message: error,\n  content_id: contentId,\n  retry_count: retryCount\n};"
      },
      "id": "4b5c6d7e-8f90-1234-56789012345678901",
      "name": "Error Handler",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1250, 500]
    }
