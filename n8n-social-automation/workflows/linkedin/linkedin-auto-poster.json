      "id": "f36f7ea2-9012-3456-7234-890123456789",
      "name": "Success Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [1850, 300]
    },
    {
      "parameters": {
        "functionCode": "// Error handling and logging\nconst error = $input.item.json.error || 'Unknown error';\nconst postId = $node[\"Get Scheduled Posts\"].json.id;\n\n// Log error to database\nawait $workflow.webhook.post('http://localhost:5678/webhook/error-log', {\n  workflow: 'LinkedIn Auto-Poster',\n  error: error,\n  post_id: postId,\n  timestamp: new Date().toISOString()\n});\n\nreturn {\n  status: 'error',\n  message: error,\n  post_id: postId\n};"
      },
      "id": "047f8eb3-0123-4567-8345-901234567890",
      "name": "Error Handler",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1050, 500]
    }
