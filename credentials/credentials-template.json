{
  "linkedin-credentials": {
    "name": "LinkedIn OAuth2 API",
    "type": "linkedInOAuth2Api",
    "data": {
      "clientId": "YOUR_LINKEDIN_CLIENT_ID",
      "clientSecret": "YOUR_LINKEDIN_CLIENT_SECRET",
      "oauthTokenData": {
        "access_token": "YOUR_LINKEDIN_ACCESS_TOKEN",
        "refresh_token": "YOUR_LINKEDIN_REFRESH_TOKEN",
        "token_type": "Bearer",
        "expires_in": 5184000
      }
    },
    "setup_instructions": [
      "1. Go to https://www.linkedin.com/developers/",
      "2. Create a new app and get Client ID and Secret",
      "3. Add redirect URI: http://localhost:5678/rest/oauth2-credential/callback",
      "4. Request permissions: r_liteprofile, r_emailaddress, w_member_social",
      "5. Complete OAuth flow in n8n to get tokens"
    ]
  },
  "instagram-credentials": {
    "name": "Instagram Basic Display API",
    "type": "instagramBasicDisplayApi",
    "data": {
      "clientId": "YOUR_INSTAGRAM_CLIENT_ID",
      "clientSecret": "YOUR_INSTAGRAM_CLIENT_SECRET",
      "accessToken": "YOUR_INSTAGRAM_ACCESS_TOKEN"
    },
    "setup_instructions": [
      "1. Go to https://developers.facebook.com/",
      "2. Create a new app and add Instagram Basic Display product",
      "3. Add redirect URI: http://localhost:5678/rest/oauth2-credential/callback",
      "4. Get App ID and App Secret",
      "5. Generate access token through OAuth flow",
      "Note: For business posting, you'll need Instagram Business API with different setup"
    ]
  },
  "google-sheets-credentials": {
    "name": "Google Sheets OAuth2 API",
    "type": "googleSheetsOAuth2Api",
    "data": {
      "clientId": "YOUR_GOOGLE_CLIENT_ID",
      "clientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
      "oauthTokenData": {
        "access_token": "YOUR_GOOGLE_ACCESS_TOKEN",
        "refresh_token": "YOUR_GOOGLE_REFRESH_TOKEN",
        "scope": "https://www.googleapis.com/auth/spreadsheets",
        "token_type": "Bearer",
        "expires_in": 3599
      }
    },
    "setup_instructions": [
      "1. Go to https://console.cloud.google.com/",
      "2. Create a new project or select existing",
      "3. Enable Google Sheets API",
      "4. Create OAuth 2.0 credentials",
      "5. Add redirect URI: http://localhost:5678/rest/oauth2-credential/callback",
      "6. Complete OAuth flow in n8n"
    ]
  },
  "telegram-credentials": {
    "name": "Telegram API",
    "type": "telegramApi",
    "data": {
      "accessToken": "YOUR_TELEGRAM_BOT_TOKEN"
    },
    "setup_instructions": [
      "1. Message @BotFather on Telegram",
      "2. Send /newbot command",
      "3. Follow instructions to create bot",
      "4. Copy the bot token",
      "5. Get your chat ID by messaging @userinfobot"
    ]
  }
}