        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "text": "={{$json[\"content\"]}}",
        "additionalFields": {
          "visibility": "PUBLIC",
          "lifecycleState": "PUBLISHED"
        }
      },
      "id": "9d0f1e4c-3456-7890-1cde-f23456789012",
