    {
      "parameters": {
        "url": "https://api.linkedin.com/v2/invitations",
        "authentication": "oAuth2",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Restli-Protocol-Version",
              "value": "2.0.0"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "invitee",
              "value": "={{ { \"com.linkedin.voyager.growth.invitation.Invitee\": { \"profile\": \"{{ $json.profileId }}\" } } }}"
            },
            {
              "name": "message",
              "value": "Hi! I'd love to connect with you on LinkedIn."
            }
          ]
        }
      },
      "id": "send-connection-request",
      "name": "Send Connection Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1120, 400],
      "credentials": {
        "linkedinOAuth2Api": {
          "id": "linkedin-credentials",
          "name": "LinkedIn OAuth2"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Generate analytics report\nconst engagement = $input.first().json;\nconst connections = $input.all()[1].json;\n\nconst report = {\n  timestamp: new Date().toISOString(),\n  engagement: {\n    likes: engagement.totalShareStatistics?.likeCount || 0,\n    comments: engagement.totalShareStatistics?.commentCount || 0,\n    shares: engagement.totalShareStatistics?.shareCount || 0,\n    views: engagement.totalShareStatistics?.impressionCount || 0\n  },\n  connections: {\n    total: connections.elements?.length || 0,\n    newThisWeek: connections.elements?.filter(c => \n      new Date(c.createdTime) > new Date(Date.now() - 7 * 24 * 60 * 60 * 1000)\n    ).length || 0\n  },\n  recommendations: generateRecommendations(engagement, connections)\n};\n\nfunction generateRecommendations(engagement, connections) {\n  const recommendations = [];\n  \n  if (engagement.totalShareStatistics?.likeCount < 10) {\n    recommendations.push('Consider posting more engaging content');\n  }\n  \n  if (connections.elements?.length < 500) {\n    recommendations.push('Focus on growing your network');\n  }\n  \n  return recommendations;\n}\n\nreturn [{ json: report }];"
      },
      "id": "generate-analytics",
      "name": "Generate Analytics Report",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "url": "https://hooks.slack.com/services/YOUR_SLACK_WEBHOOK",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "text",
              "value": "LinkedIn Automation Report: {{ $json.timestamp }}\n\nEngagement:\n- Likes: {{ $json.engagement.likes }}\n- Comments: {{ $json.engagement.comments }}\n- Shares: {{ $json.engagement.shares }}\n- Views: {{ $json.engagement.views }}\n\nConnections: {{ $json.connections.total }}\nNew this week: {{ $json.connections.newThisWeek }}\n\nRecommendations:\n{{ $json.recommendations.join('\\n') }}"
            }
          ]
        }
      },
