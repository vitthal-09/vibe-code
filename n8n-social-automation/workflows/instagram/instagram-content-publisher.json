        "query": "UPDATE content_calendar SET status = 'published', published_at = NOW(), post_id = '{{$json[\"id\"]}}', engagement_initial = 0 WHERE id = {{$node[\"Get Scheduled Content\"].json[\"id\"]}};",
        "options": {}
      },
      "id": "1e2f3a4b-5c6d-7e8f-9012345678901234",
      "name": "Update Content Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.2,
      "position": [1450, 300],
      "credentials": {
        "postgres": {
          "id": "1",
          "name": "PostgreSQL Database"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Add hashtags processing\nconst caption = $json.caption;\nconst hashtags = $json.hashtags ? JSON.parse($json.hashtags) : [];\n\n// Combine caption with hashtags\nlet fullCaption = caption;\nif (hashtags.length > 0) {\n  fullCaption += '\\n\\n' + hashtags.map(tag => `#${tag}`).join(' ');\n}\n\n// Truncate if too long (Instagram limit is 2200 characters)\nif (fullCaption.length > 2200) {\n  fullCaption = fullCaption.substring(0, 2197) + '...';\n}\n\nreturn {\n  ...items[0].json,\n  caption: fullCaption\n};"
      },
      "id": "2f3a4b5c-6d7e-8f90-123456789012345",
      "name": "Process Hashtags",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [550, 300]
    },
    {
      "parameters": {
