    {
      "parameters": {
        "functionCode": "// Generate Instagram analytics report\nconst insights = $input.first().json;\nconst posts = $input.all()[1].json;\n\nconst report = {\n  timestamp: new Date().toISOString(),\n  insights: {\n    impressions: insights.data?.find(d => d.name === 'impressions')?.values?.[0]?.value || 0,\n    reach: insights.data?.find(d => d.name === 'reach')?.values?.[0]?.value || 0,\n    profileViews: insights.data?.find(d => d.name === 'profile_views')?.values?.[0]?.value || 0,\n    followerCount: insights.data?.find(d => d.name === 'follower_count')?.values?.[0]?.value || 0\n  },\n  posts: {\n    total: posts.data?.length || 0,\n    totalLikes: posts.data?.reduce((sum, post) => sum + (post.like_count || 0), 0) || 0,\n    totalComments: posts.data?.reduce((sum, post) => sum + (post.comments_count || 0), 0) || 0,\n    averageEngagement: posts.data?.length > 0 ? \n      (posts.data?.reduce((sum, post) => sum + (post.like_count || 0) + (post.comments_count || 0), 0) / posts.data?.length) || 0 : 0\n  },\n  recommendations: generateRecommendations(insights, posts)\n};\n\nfunction generateRecommendations(insights, posts) {\n  const recommendations = [];\n  \n  const avgEngagement = posts.data?.length > 0 ? \n    (posts.data?.reduce((sum, post) => sum + (post.like_count || 0) + (post.comments_count || 0), 0) / posts.data?.length) || 0 : 0;\n  \n  if (avgEngagement < 50) {\n    recommendations.push('Consider posting more engaging content with better visuals');\n  }\n  \n  if (insights.data?.find(d => d.name === 'follower_count')?.values?.[0]?.value < 1000) {\n    recommendations.push('Focus on growing your follower base with consistent posting');\n  }\n  \n  if (posts.data?.length < 30) {\n    recommendations.push('Increase posting frequency to maintain audience engagement');\n  }\n  \n  return recommendations;\n}\n\nreturn [{ json: report }];"
      },
