        "resource": "insights",
        "operation": "getAccountInsights",
        "period": "day",
        "metrics": [
          "impressions",
          "reach",
          "profile_views"
        ]
      },
      "id": "instagram-insights",
      "name": "Instagram - Get Insights",
      "type": "n8n-nodes-base.instagram",
      "typeVersion": 1,
      "position": [
        1340,
        600
      ],
      "credentials": {
        "instagramBasicDisplayApi": {
          "id": "instagram-credentials",
          "name": "Instagram Basic Display API"
        }
